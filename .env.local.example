# ───────────────────────────────────────────────────────────────
#  The Cynic Judge — قاضي الشعب  |  Environment variables
#  Copy this file to ".env.local" and fill in your real keys.
#  NEVER commit .env.local — it is git-ignored by default.
# ───────────────────────────────────────────────────────────────

# Google Gemini (text generation)
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the Gemini model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ElevenLabs (voice generation)
# Get a key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID to speak the verdict. Pick an Arabic-capable voice from
# https://elevenlabs.io/app/voice-library  (or your own cloned voice).
ELEVENLABS_VOICE_ID=your_voice_id_here

# Optional: override the ElevenLabs model (default: eleven_multilingual_v2)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
